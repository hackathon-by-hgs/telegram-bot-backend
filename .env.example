# --- Core ---
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swiftydrop_guard?schema=public

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# HTTPS URL of the Mini App. When set, a "🚀 Open App" web_app button is added to
# the main menu and the chat menu button launches it. Domain must be registered
# with @BotFather (/setdomain). Leave blank to disable the web_app launch.
WEBAPP_URL=

# --- External data sources (all optional — modules degrade gracefully when missing) ---
CRYPTORANK_API_KEY=
ETHERSCAN_API_KEY=
MORALIS_API_KEY=
ALCHEMY_API_KEY=
COVALENT_API_KEY=
GOPLUS_APP_KEY=

# --- SwiftyEx exchange Mini App ---
SWIFTYEX_BASE_URL=http://localhost:8000
# How we authenticate to SwiftyEx:
#   forward  (default) — same Telegram bot, so we forward the user's initData verbatim.
#   service            — different bot; use chat_id + SWIFTYEX_SERVICE_TOKEN instead.
SWIFTYEX_AUTH_MODE=forward
SWIFTYEX_SERVICE_TOKEN=
# Shared secret SwiftyEx sends as the `x-swiftyex-secret` header on its webhook.
# Required for POST /api/swiftyex/webhook to be accepted (fail-closed).
SWIFTYEX_WEBHOOK_SECRET=

# --- AI (Google Gemini) ---
# Powers the airdrop scam/legitimacy detector and the recommendation engine.
# Without a key, both features degrade gracefully (no-op / legitimacy-sorted fallback).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash            # smart tier — recommendations
GEMINI_MODEL_FAST=gemini-3.1-flash-lite  # fast/cheap tier — per-airdrop scam scoring

# --- Optional infra ---
REDIS_URL=redis://localhost:6379
