// SwiftyDrop Guard — Prisma schema
// Maps directly to the DB sections of index.md (users, airdrops, tasks, user_stats, referrals, security_reports).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  telegramId    String   @unique
  username      String?
  walletAddress String?  @unique
  referralCode  String   @unique
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  createdAt     DateTime @default(now())

  // AI recommendation preferences:
  // { categories: string[], chains: string[], riskTolerance: low|medium|high, effort: low|medium|high }
  preferences   Json?

  stats             UserStats?
  tasks             AirdropTask[]
  referralsGranted  Referral[] @relation("ReferralReferrer")
  referralsReceived Referral[] @relation("ReferralReferred")
  notifications     Notification[]
  swiftyEx          SwiftyExAccount?
}

model UserStats {
  userId String   @id
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp     Int      @default(0)
  streak Int      @default(0)
  level  Int      @default(1)
  badges String[] @default([])
  lastActiveAt DateTime @default(now())
}

model Airdrop {
  id              String   @id @default(cuid())
  externalId      String   @unique
  name            String
  description     String?
  rewardEstimate  String?
  deadline        DateTime?
  category        String?
  trustScore      Int?
  difficulty      String?
  projectUrl      String?  // canonical project/campaign link
  socialLinks     Json?
  source          String
  createdAt       DateTime @default(now())

  // Gemini legitimacy/longevity assessment (separate from the rule-based SecurityReport).
  aiLegitScore    Int?      // 0-100, higher = more legitimate / promising
  aiOutlook       String?   // promising | uncertain | likely_dead | scam
  aiSerious       Boolean?  // is this a serious project with a real future
  aiFlags         String[]  @default([])
  aiSummary       String?
  aiAssessedAt    DateTime?

  securityReports SecurityReport[]
  airdropTasks    AirdropTask[]
}

model SecurityReport {
  id              String   @id @default(cuid())
  airdropId       String?
  airdrop         Airdrop? @relation(fields: [airdropId], references: [id], onDelete: SetNull)
  subject         String   // domain / contract / wallet
  trustScore      Int
  scamProbability Int
  riskLevel       String   // low | medium | high
  warnings        String[] @default([])
  explanation     String
  createdAt       DateTime @default(now())
}

model AirdropTask {
  id          String   @id @default(cuid())
  airdropId   String
  airdrop     Airdrop  @relation(fields: [airdropId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  status      String   @default("pending") // pending | in_progress | completed
  progress    Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, airdropId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String   @unique
  referredUser   User     @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  rewardGranted  Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String   // telegram | push
  type      String
  payload   Json
  status    String   @default("queued") // queued | sent | failed
  createdAt DateTime @default(now())
  sentAt    DateTime?
}

// --- SwiftyEx integration (cache of the external exchange Mini App) ---
// Joined to User by chatId == User.telegramId == SwiftyEx Chat.chat_id.
// Lets crons / gamification / notifications read SwiftyEx state without a live
// initData-authenticated call.
model SwiftyExAccount {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId       String   @unique
  kycVerified  Boolean  @default(false)
  kycLevel     Int      @default(0)
  referralCode String?
  wallets      Json     @default("[]") // [{ wallet_type, blockchain, balance, address }]
  syncedAt     DateTime @default(now())
}

// Cache of the public GET /miniapp/rates feed, refreshed by AlertsCron.
model SwiftyExRate {
  asset     String   @id // "btc" | "ethereum" | "usdt" | "naira" ...
  buyRate   Float
  sellRate  Float
  updatedAt DateTime @default(now())
}
